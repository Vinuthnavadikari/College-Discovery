generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model College {
  id             String   @id @default(cuid())
  name           String
  location       String
  state          String
  fees           Int
  rating         Float
  avgPackage     Float
  highestPackage Float
  placementRate  Int
  description    String
  createdAt      DateTime @default(now())
}